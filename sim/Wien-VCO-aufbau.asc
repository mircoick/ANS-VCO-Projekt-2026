TEXT 824 -2832 Left 2 !* Includes\n.include ../kicad/spicelibs/MAX4104.lib\n.include ../kicad/spicelibs/elk.lib\n \n* Parameter\n.param R=3k3\n.param C=15pF\n \n \n* Initial Condition\n.nodeset V(va)=1\n \n* Models\n.model 1N6263 D(Is=1.82u Rs=2.8 N=1.7 Cjo=2.65p M=0.333 tt=1.44n BV=60 Ibv=200n)\n \n* Analysemethode\n.tran 1n 200u\n \n.meas tran t1 trig V(va) val=0 rise=1\n.meas tran t2 trig V(va) val=0 rise=11\n.meas TRAN frequenz PARAM abs(10/(t2-t1))
