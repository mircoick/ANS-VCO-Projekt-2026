TEXT 824 -2832 Left 2 !* Includes\n.include ../kicad/spicelibs/MAX4104.lib\n.include ../kicad/spicelibs/elk.lib\n \n* Parameter\n.param R=3K275\n.param C=2.7pF\n \n* Step-Parameter\n.step V1 0V 1V 0.1V\n \n* Initial Condition\n.nodeset V(va)=1\n \n* Models\n.model BB535/SIE D (IS=1.75E-15 N=1.043 RS=60E-3 XTI=3 EG=1.11 CJO=25.31E-12 M=1.064 VJ=3.022 FC=.5 BV=32 IBV=100E-9 TT=120E-9 )\n.model 1N6263 D(Is=1.82u Rs=2.8 N=1.7 Cjo=2.65p M=0.333 tt=1.44n BV=60 Ibv=200n)\n \n* Analysemethode\n.tran 0 900u 800u\n \n.meas tran t1 trig V(va) val=0 rise=1\n.meas tran t2 trig V(va) val=0 rise=11\n.meas TRAN frequenz PARAM abs(10/(t2-t1))
